{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/api/visit",
        "function": { "functionId": "recordVisit", "region": "us-central1" }
      },
      {
        "source": "/api/booking",
        "function": { "functionId": "submitBooking", "region": "us-central1" }
      },
      {
        "source": "/api/feedback",
        "function": { "functionId": "postFeedback", "region": "us-central1" }
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  }
}
