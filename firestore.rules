rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only the owner (verified email) can read/write content. The public site
    // does not read Firestore at runtime; the build-time pull uses the Admin SDK
    // which bypasses these rules.
    match /content/{doc} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'luis.atorred24@gmail.com';
    }
    match /analytics/{doc} {
      allow read: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'luis.atorred24@gmail.com';
      allow write: if false;
    }
    // Bookings are written only by the submitBooking function (Admin SDK
    // bypasses rules); the owner reads/updates them from /admin.
    match /bookings/{doc} {
      allow read, update, delete: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'luis.atorred24@gmail.com';
      allow create: if false;
    }
    // Posts are edited only by the owner; the public site reads them from the
    // published JSON mirror, never from Firestore.
    match /posts/{doc} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'luis.atorred24@gmail.com';
    }
    // Feedback aggregates/votes are written only by the postFeedback function;
    // the owner can read them for auditing.
    match /feedback/{document=**} {
      allow read: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'luis.atorred24@gmail.com';
      allow write: if false;
    }
    // Comments are created by the function; the owner moderates them.
    match /comments/{doc} {
      allow read, update, delete: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'luis.atorred24@gmail.com';
      allow create: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
